    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "stylelint": "^17.5.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "modern-normalize": "^3.0.1"
  }
